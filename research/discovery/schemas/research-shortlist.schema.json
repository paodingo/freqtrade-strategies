{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "discovery_run_id",
    "eligible_idea_count",
    "ranking_policy_version",
    "ranked_ideas",
    "recommended_idea_id",
    "recommendation",
    "recommendation_reason_zh",
    "research_state_fingerprint",
    "shortlist_fingerprint"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "const": "research-shortlist-v1"
    },
    "discovery_run_id": {
      "type": "string",
      "minLength": 1
    },
    "eligible_idea_count": {
      "type": "integer",
      "minimum": 0
    },
    "ranking_policy_version": {
      "type": "string",
      "minLength": 1,
      "const": "research-ranking-policy-v1"
    },
    "ranked_ideas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "idea_id",
          "idea_fingerprint",
          "critique_fingerprint",
          "strategy_family",
          "risk_class",
          "cost_class",
          "final_score"
        ],
        "properties": {
          "idea_id": {
            "type": "string",
            "minLength": 1
          },
          "idea_fingerprint": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-f0-9]{64}$"
          },
          "critique_fingerprint": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-f0-9]{64}$"
          },
          "strategy_family": {
            "type": "string",
            "minLength": 1
          },
          "risk_class": {
            "type": "string",
            "minLength": 1,
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "cost_class": {
            "type": "string",
            "minLength": 1,
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "final_score": {
            "type": "number"
          }
        },
        "additionalProperties": false
      },
      "maxItems": 3
    },
    "recommended_idea_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "recommendation": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "research_recommended",
        "no_research_recommended"
      ]
    },
    "recommendation_reason_zh": {
      "type": "string",
      "minLength": 1
    },
    "research_state_fingerprint": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-f0-9]{64}$"
    },
    "shortlist_fingerprint": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "ranked_ideas": {
            "maxItems": 0
          }
        },
        "required": [
          "ranked_ideas"
        ]
      },
      "then": {
        "properties": {
          "recommended_idea_id": {
            "type": "null"
          },
          "recommendation": {
            "const": "no_research_recommended"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "recommendation": {
            "const": "research_recommended"
          }
        },
        "required": [
          "recommendation"
        ]
      },
      "then": {
        "properties": {
          "ranked_ideas": {
            "minItems": 1
          },
          "recommended_idea_id": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ]
}
