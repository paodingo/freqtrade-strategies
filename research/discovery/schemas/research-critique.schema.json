{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "critique_id",
    "idea_id",
    "idea_semantic_fingerprint",
    "verdict",
    "source_verification",
    "duplicate_research_check",
    "falsifiability_assessment",
    "data_readiness_assessment",
    "leakage_and_overfit_risks",
    "transaction_cost_challenge",
    "strongest_counterevidence",
    "alternative_explanations",
    "fatal_objections",
    "score_adjustments",
    "ranking_inputs",
    "critic_fingerprint"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "const": "research-critique-v1"
    },
    "critique_id": {
      "type": "string",
      "minLength": 1
    },
    "idea_id": {
      "type": "string",
      "minLength": 1
    },
    "idea_semantic_fingerprint": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-f0-9]{64}$"
    },
    "verdict": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "pass",
        "revise",
        "reject"
      ]
    },
    "source_verification": {
      "type": "object",
      "required": [
        "highest_class"
      ],
      "properties": {
        "highest_class": {
          "type": "string",
          "minLength": 1,
          "enum": [
            "A",
            "B",
            "C"
          ]
        }
      },
      "additionalProperties": false
    },
    "duplicate_research_check": {
      "type": "string",
      "minLength": 1
    },
    "falsifiability_assessment": {
      "type": "string",
      "minLength": 1
    },
    "data_readiness_assessment": {
      "type": "string",
      "minLength": 1
    },
    "leakage_and_overfit_risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "transaction_cost_challenge": {
      "type": "string",
      "minLength": 1
    },
    "strongest_counterevidence": {
      "type": "string",
      "minLength": 1
    },
    "alternative_explanations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fatal_objections": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "score_adjustments": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "knowledge_verification": {
      "type": "object",
      "required": [
        "selection_id",
        "selection_fingerprint",
        "idea_knowledge_use_verified",
        "lesson_checks",
        "status",
        "notes"
      ],
      "properties": {
        "selection_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^knowledge-selection-[a-f0-9]{16}$"
        },
        "selection_fingerprint": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-f0-9]{64}$"
        },
        "idea_knowledge_use_verified": {"type": "boolean"},
        "lesson_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["lesson_id", "result"],
            "properties": {
              "lesson_id": {"type": "string", "minLength": 1},
              "result": {
                "type": "string",
                "minLength": 1,
                "enum": ["confirmed_distinct", "semantic_duplicate", "not_applicable"]
              }
            },
            "additionalProperties": false
          },
          "uniqueItems": true
        },
        "status": {
          "type": "string",
          "minLength": 1,
          "enum": ["verified", "semantic_duplicate", "invalid_binding"]
        },
        "notes": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "ranking_inputs": {
      "type": "object",
      "required": [
        "expected_information_gain",
        "falsifiability_and_mechanism_clarity",
        "feasibility_with_existing_data",
        "novelty_and_non_duplication",
        "robustness_relevance"
      ],
      "properties": {
        "expected_information_gain": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "falsifiability_and_mechanism_clarity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "feasibility_with_existing_data": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "novelty_and_non_duplication": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "robustness_relevance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "critic_fingerprint": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "additionalProperties": false
}
