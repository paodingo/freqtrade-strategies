{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "research/director/research-proposal.schema.json",
  "title": "Research Director Proposal",
  "type": "object",
  "required": [
    "schema_version", "proposal_id", "title", "research_question", "current_uncertainty",
    "supporting_evidence", "contradictory_evidence", "expected_information_gain",
    "proposed_method", "immutable_inputs", "allowed_changes", "forbidden_changes",
    "required_datasets", "required_runtime", "required_policy", "estimated_experiments",
    "estimated_wall_clock_minutes", "estimated_compute_cost", "risk_class",
    "contamination_risk", "validation_requirement", "holdout_requirement",
    "branch_closure_reopen_check", "duplicate_research_check", "stop_conditions",
    "success_criteria", "failure_does_not_imply", "required_artifacts", "required_tests",
    "approval_requirement", "recommendation_confidence", "recommendation",
    "semantic_fingerprint", "research_question_fingerprint"
  ],
  "properties": {
    "schema_version": {"const": "research-proposal-v1"},
    "proposal_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]+$"},
    "title": {"type": "string", "minLength": 1},
    "research_question": {"type": "string", "minLength": 1},
    "current_uncertainty": {"type": "string"},
    "supporting_evidence": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["path", "claim"]}},
    "contradictory_evidence": {"type": "array", "items": {"type": "object"}},
    "expected_information_gain": {"type": "object", "required": ["score", "level", "rationale"]},
    "proposed_method": {"type": "object"},
    "immutable_inputs": {"type": "array"},
    "allowed_changes": {"type": "array"},
    "forbidden_changes": {"type": "array"},
    "required_datasets": {"type": "array"},
    "required_runtime": {"type": "object"},
    "required_policy": {"type": "object"},
    "estimated_experiments": {"type": "integer", "minimum": 0},
    "estimated_wall_clock_minutes": {"type": "integer", "minimum": 0},
    "estimated_compute_cost": {"enum": ["low", "medium", "high"]},
    "risk_class": {"enum": ["low", "medium", "high", "forbidden"]},
    "contamination_risk": {"enum": ["none", "low", "medium", "high"]},
    "validation_requirement": {"enum": ["none", "human_approval_required", "forbidden"]},
    "holdout_requirement": {"enum": ["none", "human_approval_required", "forbidden"]},
    "branch_closure_reopen_check": {"type": "object", "required": ["checked", "blocked", "reason_code"]},
    "duplicate_research_check": {"type": "object", "required": ["checked", "duplicate", "reason_code"]},
    "stop_conditions": {"type": "array", "minItems": 1},
    "success_criteria": {"type": "array", "minItems": 1},
    "failure_does_not_imply": {"type": "array"},
    "required_artifacts": {"type": "array", "minItems": 1},
    "required_tests": {"type": "array", "minItems": 1},
    "approval_requirement": {"enum": ["auto_approvable_future", "auto_approved_under_constitution", "auto_approved_under_stage4c1_portfolio", "human_approval_required", "forbidden", "insufficient_information"]},
    "execution_authorized": {"type": "boolean"},
    "descriptive_execution_authorized": {"type": "boolean"},
    "descriptive_execution_authorization": {"type": "object"},
    "recommendation_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "recommendation": {"enum": ["research_recommended", "no_research_recommended"]},
    "semantic_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "research_question_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "additionalProperties": true
}
