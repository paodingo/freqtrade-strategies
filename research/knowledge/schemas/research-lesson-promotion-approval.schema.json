{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "approval_id", "reviewer_type", "reviewer_id", "statement", "decided_at", "packet_fingerprint", "decisions", "approved_count", "rejected_count", "automatic_lesson_promotion_authorized", "trading_execution_authorized", "approval_fingerprint"],
  "properties": {
    "schema_version": {"const": "research-lesson-promotion-approval-v1"},
    "approval_id": {"type": "string", "minLength": 1},
    "reviewer_type": {"const": "human_user"},
    "reviewer_id": {"type": "string", "minLength": 1},
    "statement": {"type": "string", "minLength": 1},
    "decided_at": {"type": "string", "minLength": 1},
    "packet_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["candidate_id", "candidate_fingerprint", "decision"],
        "properties": {
          "candidate_id": {"type": "string", "minLength": 1},
          "candidate_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "decision": {"enum": ["approved", "rejected"]}
        },
        "additionalProperties": false
      }
    },
    "approved_count": {"type": "integer", "minimum": 0},
    "rejected_count": {"type": "integer", "minimum": 0},
    "automatic_lesson_promotion_authorized": {"const": false},
    "trading_execution_authorized": {"const": false},
    "approval_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "additionalProperties": false
}
