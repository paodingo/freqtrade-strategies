{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "advisory_id", "generated_at", "packet_fingerprint", "recommendations", "summary", "human_decision_required", "automatic_application_authorized", "execution_authorized", "advisory_fingerprint"],
  "properties": {
    "schema_version": {"const": "knowledge-review-recommendations-v1"},
    "advisory_id": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "minLength": 1},
    "packet_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["review_key", "review_type", "target_id", "recommended_decision", "confidence", "disposition", "rationale", "references", "constraints"],
        "properties": {
          "review_key": {"type": "string", "minLength": 1},
          "review_type": {"enum": ["source_update", "lesson_feedback", "license_review"]},
          "target_id": {"type": "string", "minLength": 1},
          "recommended_decision": {"enum": ["approved", "rejected"]},
          "confidence": {"enum": ["high", "medium", "low"]},
          "disposition": {"enum": ["curate_standalone", "merge_into_final_lesson", "reject_invalidated", "reject_duplicate", "correct_metadata_after_approval", "keep_current_pin"]},
          "rationale": {"type": "string", "minLength": 1},
          "references": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true},
          "constraints": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true}
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": ["approved", "rejected", "total"],
      "properties": {
        "approved": {"type": "integer", "minimum": 0},
        "rejected": {"type": "integer", "minimum": 0},
        "total": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "human_decision_required": {"const": true},
    "automatic_application_authorized": {"const": false},
    "execution_authorized": {"const": false},
    "advisory_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "additionalProperties": false
}
