{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "intent_id",
    "batch_id",
    "reviewer_type",
    "reviewer_id",
    "decision",
    "statement",
    "decided_at",
    "authorization_source",
    "packet_fingerprint",
    "advisory_fingerprint",
    "approved_count",
    "rejected_count",
    "review_event_application_authorized",
    "automatic_source_update_authorized",
    "automatic_lesson_promotion_authorized",
    "execution_authorized",
    "intent_fingerprint"
  ],
  "properties": {
    "schema_version": {"const": "knowledge-review-human-intent-v1"},
    "intent_id": {"type": "string", "pattern": "^knowledge-review-human-intent-[a-f0-9]{16}$"},
    "batch_id": {"type": "string", "pattern": "^knowledge-review-batch-[a-f0-9]{16}$"},
    "reviewer_type": {"const": "human_user"},
    "reviewer_id": {"type": "string", "minLength": 1},
    "decision": {"const": "approve_recommendations"},
    "statement": {"type": "string", "minLength": 1},
    "decided_at": {"type": "string", "minLength": 1},
    "authorization_source": {"const": "explicit_user_instruction"},
    "packet_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "advisory_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "approved_count": {"type": "integer", "minimum": 0},
    "rejected_count": {"type": "integer", "minimum": 0},
    "review_event_application_authorized": {"const": true},
    "automatic_source_update_authorized": {"const": false},
    "automatic_lesson_promotion_authorized": {"const": false},
    "execution_authorized": {"const": false},
    "intent_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "additionalProperties": false
}
