{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "evaluation_id", "knowledge_snapshot_fingerprint", "case_count", "hit_rate_at_4", "first_rank_rate", "threshold", "status", "cases", "evaluation_fingerprint"],
  "properties": {
    "schema_version": {"const": "knowledge-retrieval-evaluation-v1"},
    "evaluation_id": {"type": "string", "minLength": 1},
    "knowledge_snapshot_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "case_count": {"type": "integer", "minimum": 1},
    "hit_rate_at_4": {"type": "number", "minimum": 0, "maximum": 1},
    "first_rank_rate": {"type": "number", "minimum": 0, "maximum": 1},
    "threshold": {"type": "number", "minimum": 0, "maximum": 1},
    "status": {"type": "string", "enum": ["passed", "failed"]},
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["case_id", "query", "expected_type", "expected_id", "rank", "hit"],
        "properties": {
          "case_id": {"type": "string", "minLength": 1},
          "query": {"type": "string", "minLength": 1},
          "expected_type": {"type": "string", "enum": ["pattern", "lesson"]},
          "expected_id": {"type": "string", "minLength": 1},
          "rank": {"type": ["integer", "null"], "minimum": 1},
          "hit": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "evaluation_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "additionalProperties": false
}
