{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "checked_at", "projects", "summary", "automatic_update_authorized", "report_fingerprint"],
  "properties": {
    "schema_version": {"const": "knowledge-source-refresh-report-v1"},
    "checked_at": {"type": "string", "minLength": 1},
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["project_id", "canonical_url", "branch", "pinned_commit", "upstream_commit", "status", "license_status", "human_approval_required", "proposal_id"],
        "properties": {
          "project_id": {"type": "string", "minLength": 1},
          "canonical_url": {"type": "string", "minLength": 1},
          "branch": {"type": "string", "minLength": 1},
          "pinned_commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
          "upstream_commit": {"type": ["string", "null"], "pattern": "^[a-f0-9]{40}$"},
          "status": {"type": "string", "enum": ["current", "update_available", "check_failed"]},
          "license_status": {"type": "string", "enum": ["asserted", "review_required"]},
          "error": {"type": ["string", "null"]},
          "human_approval_required": {"const": true},
          "proposal_id": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": ["current", "update_available", "check_failed", "license_review_required"],
      "properties": {
        "current": {"type": "integer", "minimum": 0},
        "update_available": {"type": "integer", "minimum": 0},
        "check_failed": {"type": "integer", "minimum": 0},
        "license_review_required": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "automatic_update_authorized": {"const": false},
    "report_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "additionalProperties": false
}
