{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version", "snapshot_id", "project_id", "canonical_url",
    "commit_sha", "default_branch", "retrieved_at", "source_class",
    "publisher_type", "license_spdx", "licensing_constraints", "scope",
    "claims", "content_fingerprint", "full_source_stored",
    "code_reuse_authorized", "status"
  ],
  "properties": {
    "schema_version": {"const": "open-source-source-snapshot-v1"},
    "snapshot_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]+@[a-f0-9]{40}$"},
    "project_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]+$"},
    "canonical_url": {"type": "string", "pattern": "^https://github\\.com/"},
    "commit_sha": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "default_branch": {"type": "string", "minLength": 1},
    "retrieved_at": {"type": "string", "format": "date-time"},
    "source_class": {"const": "C"},
    "publisher_type": {"const": "public_strategy_repository"},
    "license_spdx": {"type": "string", "minLength": 1},
    "licensing_constraints": {"type": "string", "minLength": 1},
    "scope": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "claims": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "content_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "fingerprint_basis": {"type": "string", "minLength": 1},
    "full_source_stored": {"const": false},
    "code_reuse_authorized": {"const": false},
    "status": {"enum": ["active_reference_only", "stale_reference_only", "license_review_required"]}
  },
  "additionalProperties": false
}
