{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "batch_id",
    "batch_basis_at",
    "trigger_reason",
    "thresholds",
    "counts",
    "oldest_pending_at",
    "newest_pending_at",
    "policy_path",
    "policy_fingerprint",
    "packet_path",
    "packet_fingerprint",
    "planned_advisory_path",
    "planned_human_intent_path",
    "planned_approval_path",
    "planned_review_events_path",
    "planned_post_approval_plan_path",
    "planned_curation_draft_path",
    "planned_curation_candidate_root",
    "planned_promotion_review_packet_path",
    "planned_promotion_base_context_path",
    "planned_promotion_base_manifest_path",
    "planned_promotion_human_intent_path",
    "planned_promotion_approval_path",
    "planned_promotion_events_path",
    "planned_published_manifest_path",
    "required_next_action",
    "human_decision_required",
    "advisory_drafting_authorized",
    "automatic_decision_authorized",
    "automatic_application_authorized",
    "automatic_lesson_promotion_authorized",
    "execution_authorized",
    "handoff_fingerprint"
  ],
  "properties": {
    "schema_version": {"const": "knowledge-review-batch-handoff-v1"},
    "batch_id": {"type": "string", "pattern": "^knowledge-review-batch-[a-f0-9]{16}$"},
    "batch_basis_at": {"type": "string", "minLength": 1},
    "trigger_reason": {"enum": ["count_threshold", "max_wait_threshold"]},
    "thresholds": {
      "type": "object",
      "required": ["count_threshold", "max_wait_hours"],
      "properties": {
        "count_threshold": {"type": "integer", "minimum": 1},
        "max_wait_hours": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "counts": {
      "type": "object",
      "required": ["source_updates", "lesson_feedback", "license_reviews", "total"],
      "properties": {
        "source_updates": {"type": "integer", "minimum": 0},
        "lesson_feedback": {"type": "integer", "minimum": 0},
        "license_reviews": {"type": "integer", "minimum": 0},
        "total": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "oldest_pending_at": {"type": "string", "minLength": 1},
    "newest_pending_at": {"type": "string", "minLength": 1},
    "policy_path": {"const": "research/director/knowledge-review-batch-policy-v1.json"},
    "policy_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "packet_path": {"type": "string", "pattern": "^reports/audits/open-source-learning-v1/review-batches/aggregated/knowledge-review-batch-[a-f0-9]{16}/packet\\.json$"},
    "packet_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "planned_advisory_path": {"type": "string", "pattern": "^reports/audits/open-source-learning-v1/review-batches/aggregated/knowledge-review-batch-[a-f0-9]{16}/recommendations\\.json$"},
    "planned_human_intent_path": {"type": "string", "pattern": "^reports/audits/open-source-learning-v1/review-batches/aggregated/knowledge-review-batch-[a-f0-9]{16}/human-intent\\.json$"},
    "planned_approval_path": {"type": "string", "pattern": "^reports/audits/open-source-learning-v1/review-batches/aggregated/knowledge-review-batch-[a-f0-9]{16}/batch-approval\\.json$"},
    "planned_review_events_path": {"type": "string", "pattern": "^reports/audits/open-source-learning-v1/review-batches/aggregated/knowledge-review-batch-[a-f0-9]{16}/review-events\\.json$"},
    "planned_post_approval_plan_path": {"type": "string", "pattern": "^reports/audits/open-source-learning-v1/review-batches/aggregated/knowledge-review-batch-[a-f0-9]{16}/post-approval-plan\\.json$"},
    "planned_curation_draft_path": {"type": "string", "pattern": "^reports/audits/open-source-learning-v1/review-batches/aggregated/knowledge-review-batch-[a-f0-9]{16}/curation-draft-packet\\.json$"},
    "planned_curation_candidate_root": {"type": "string", "pattern": "^reports/audits/open-source-learning-v1/review-batches/aggregated/knowledge-review-batch-[a-f0-9]{16}/lesson-candidates$"},
    "planned_promotion_review_packet_path": {"type": "string", "pattern": "^reports/audits/open-source-learning-v1/review-batches/aggregated/knowledge-review-batch-[a-f0-9]{16}/promotion-review-packet\\.json$"},
    "planned_promotion_base_context_path": {"type": "string", "pattern": "^reports/audits/open-source-learning-v1/review-batches/aggregated/knowledge-review-batch-[a-f0-9]{16}/promotion-base-context\\.json$"},
    "planned_promotion_base_manifest_path": {"type": "string", "pattern": "^reports/audits/open-source-learning-v1/review-batches/aggregated/knowledge-review-batch-[a-f0-9]{16}/promotion-base-manifest\\.json$"},
    "planned_promotion_human_intent_path": {"type": "string", "pattern": "^reports/audits/open-source-learning-v1/review-batches/aggregated/knowledge-review-batch-[a-f0-9]{16}/promotion-human-intent\\.json$"},
    "planned_promotion_approval_path": {"type": "string", "pattern": "^reports/audits/open-source-learning-v1/review-batches/aggregated/knowledge-review-batch-[a-f0-9]{16}/promotion-approval\\.json$"},
    "planned_promotion_events_path": {"type": "string", "pattern": "^reports/audits/open-source-learning-v1/review-batches/aggregated/knowledge-review-batch-[a-f0-9]{16}/promotion-events\\.json$"},
    "planned_published_manifest_path": {"type": "string", "pattern": "^reports/audits/open-source-learning-v1/review-batches/aggregated/knowledge-review-batch-[a-f0-9]{16}/published-knowledge-manifest\\.json$"},
    "required_next_action": {"const": "human_review_recommendations_then_explicit_batch_approval"},
    "human_decision_required": {"const": true},
    "advisory_drafting_authorized": {"const": true},
    "automatic_decision_authorized": {"const": false},
    "automatic_application_authorized": {"const": false},
    "automatic_lesson_promotion_authorized": {"const": false},
    "execution_authorized": {"const": false},
    "handoff_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "additionalProperties": false
}
