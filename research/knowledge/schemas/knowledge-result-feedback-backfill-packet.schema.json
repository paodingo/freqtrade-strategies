{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version", "packet_id", "source_health_fingerprint",
    "knowledge_snapshot_fingerprint", "registry_integrity", "item_count",
    "items", "decision_contract", "human_decision_required",
    "automatic_application_authorized", "automatic_lesson_promotion_authorized",
    "candidate_creation_authorized", "execution_authorized", "packet_fingerprint"
  ],
  "properties": {
    "schema_version": {"const": "knowledge-result-feedback-backfill-packet-v1"},
    "packet_id": {"type": "string", "pattern": "^knowledge-result-feedback-backfill-[a-f0-9]{16}$"},
    "source_health_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "knowledge_snapshot_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "registry_integrity": {"const": "ok"},
    "item_count": {"type": "integer", "minimum": 1},
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "ordinal", "run_id", "selected_idea_id", "proposal_id",
          "proposal_semantic_fingerprint", "discovery_handoff_fingerprint",
          "analysis_schema_version", "completed_at", "result_code",
          "outcome_class", "registration_mode", "evidence_artifacts",
          "proposed_result_id", "proposed_feedback_id",
          "proposed_feedback_review_status", "result_payload_fingerprint",
          "governance_boundaries", "item_fingerprint"
        ],
        "properties": {
          "ordinal": {"type": "integer", "minimum": 1},
          "run_id": {"type": "string", "minLength": 1},
          "selected_idea_id": {"type": "string", "minLength": 1},
          "proposal_id": {"type": "string", "minLength": 1},
          "proposal_semantic_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "discovery_handoff_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "analysis_schema_version": {"enum": ["additional-pair-manifest-inventory-analysis-v1", "discovery-cross-pair-descriptive-analysis-v1"]},
          "completed_at": {"type": "string", "minLength": 1},
          "result_code": {"type": "string", "minLength": 1},
          "outcome_class": {"const": "inconclusive"},
          "registration_mode": {"const": "historical_manual_descriptive_analysis"},
          "evidence_artifacts": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "object",
              "required": ["path", "sha256"],
              "properties": {
                "path": {"type": "string", "minLength": 1},
                "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
              },
              "additionalProperties": false
            }
          },
          "proposed_result_id": {"type": "string", "pattern": "^historical-descriptive-result-[a-f0-9]{16}$"},
          "proposed_feedback_id": {"type": "string", "pattern": "^feedback-historical-descriptive-result-[a-f0-9]{16}$"},
          "proposed_feedback_review_status": {"const": "pending_human_review"},
          "result_payload_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "governance_boundaries": {
            "type": "object",
            "required": [
              "development_only", "network_accesses", "backtests",
              "signals_or_trades_generated", "candidates_created",
              "strategy_changes", "validation_accesses", "holdout_accesses",
              "promotions"
            ],
            "properties": {
              "development_only": {"const": true},
              "network_accesses": {"const": 0},
              "backtests": {"const": 0},
              "signals_or_trades_generated": {"const": 0},
              "candidates_created": {"const": 0},
              "strategy_changes": {"const": 0},
              "validation_accesses": {"const": 0},
              "holdout_accesses": {"const": 0},
              "promotions": {"const": 0}
            },
            "additionalProperties": false
          },
          "item_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        },
        "additionalProperties": false
      }
    },
    "decision_contract": {
      "type": "object",
      "required": [
        "allowed_decisions", "approve_all_statement_zh",
        "partial_decision_instruction_zh", "approved_result",
        "rejected_result"
      ],
      "properties": {
        "allowed_decisions": {"const": ["approved", "rejected"]},
        "approve_all_statement_zh": {"type": "string", "minLength": 1},
        "partial_decision_instruction_zh": {"type": "string", "minLength": 1},
        "approved_result": {"const": "register_result_and_pending_human_review_feedback_atomically"},
        "rejected_result": {"const": "leave_historical_artifacts_unregistered"}
      },
      "additionalProperties": false
    },
    "human_decision_required": {"const": true},
    "automatic_application_authorized": {"const": false},
    "automatic_lesson_promotion_authorized": {"const": false},
    "candidate_creation_authorized": {"const": false},
    "execution_authorized": {"const": false},
    "packet_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "additionalProperties": false
}
