{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version", "lesson_id", "title_zh", "outcome",
    "mechanism_keys", "scope", "summary_zh", "evidence_paths",
    "source_class", "reuse_policy", "validation_accesses",
    "holdout_accesses", "lesson_fingerprint"
  ],
  "properties": {
    "schema_version": {"const": "research-lesson-card-v1"},
    "lesson_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]+$"},
    "title_zh": {"type": "string", "minLength": 1},
    "outcome": {"enum": ["rejected_degradation", "negative_contributor", "invalidated_engineering", "closed_evidence_exhausted", "retained", "descriptive_not_generalized", "insufficient_causal_evidence", "verified_engineering", "structural_no_mutation", "research_direction_retained"]},
    "mechanism_keys": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]+$"}, "uniqueItems": true},
    "scope": {"type": "object", "minProperties": 1},
    "summary_zh": {"type": "string", "minLength": 1},
    "metrics": {"type": "object"},
    "evidence_paths": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "source_class": {"const": "A"},
    "reuse_policy": {"enum": ["block_semantic_duplicate", "warn_and_require_material_difference", "require_recertification"]},
    "validation_accesses": {"const": 0},
    "holdout_accesses": {"const": 0},
    "lesson_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "additionalProperties": false
}
