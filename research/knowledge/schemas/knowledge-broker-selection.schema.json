{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "selection_id",
    "selection_fingerprint",
    "knowledge_snapshot_fingerprint",
    "trigger_fingerprint",
    "query_terms",
    "selected_patterns",
    "selected_lessons",
    "limits",
    "governance"
  ],
  "properties": {
    "schema_version": {"const": "knowledge-broker-selection-v1"},
    "selection_id": {"type": "string", "pattern": "^knowledge-selection-[a-f0-9]{16}$"},
    "selection_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "knowledge_snapshot_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "trigger_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "query_terms": {
      "type": "array",
      "maxItems": 32,
      "items": {"type": "string", "minLength": 1, "maxLength": 256},
      "uniqueItems": true
    },
    "selected_patterns": {
      "type": "array",
      "maxItems": 4,
      "items": {"$ref": "#/$defs/patternSelection"}
    },
    "selected_lessons": {
      "type": "array",
      "maxItems": 4,
      "items": {"$ref": "#/$defs/lessonSelection"}
    },
    "limits": {
      "type": "object",
      "required": ["max_patterns", "max_lessons", "ranking"],
      "properties": {
        "max_patterns": {"const": 4},
        "max_lessons": {"const": 4},
        "ranking": {"const": "deterministic_weighted_lexical_v2"}
      },
      "additionalProperties": false
    },
    "governance": {
      "type": "object",
      "required": [
        "class_c_only_result",
        "proposal_requirement",
        "candidate_creation_authorized",
        "backtest_authorized",
        "strategy_mutation_authorized"
      ],
      "properties": {
        "class_c_only_result": {"const": "reject"},
        "proposal_requirement": {"const": "at_least_one_A_or_B"},
        "candidate_creation_authorized": {"const": false},
        "backtest_authorized": {"const": false},
        "strategy_mutation_authorized": {"const": false}
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "commonSelection": {
      "type": "object",
      "required": ["score", "matched_mechanism_keys"],
      "properties": {
        "score": {"type": "integer", "minimum": 1},
        "matched_mechanism_keys": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    },
    "patternSelection": {
      "allOf": [
        {"$ref": "#/$defs/commonSelection"},
        {
          "type": "object",
          "required": [
            "pattern_id",
            "title_zh",
            "strategy_family",
            "mechanism_summary_zh",
            "local_data_readiness",
            "proposal_eligibility"
          ],
          "properties": {
            "pattern_id": {"type": "string", "minLength": 1},
            "title_zh": {"type": "string", "minLength": 1},
            "strategy_family": {"type": "string", "minLength": 1},
            "mechanism_summary_zh": {"type": "string", "minLength": 1},
            "local_data_readiness": {"type": "string", "minLength": 1},
            "proposal_eligibility": {"const": "inspiration_only_requires_A_or_B"}
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "lessonSelection": {
      "allOf": [
        {"$ref": "#/$defs/commonSelection"},
        {
          "type": "object",
          "required": [
            "lesson_id",
            "title_zh",
            "outcome",
            "summary_zh",
            "reuse_policy",
            "evidence_paths"
          ],
          "properties": {
            "lesson_id": {"type": "string", "minLength": 1},
            "title_zh": {"type": "string", "minLength": 1},
            "outcome": {"type": "string", "minLength": 1},
            "summary_zh": {"type": "string", "minLength": 1},
            "reuse_policy": {"type": "string", "minLength": 1},
            "evidence_paths": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "minLength": 1},
              "uniqueItems": true
            }
          }
        }
      ],
      "unevaluatedProperties": false
    }
  },
  "additionalProperties": false
}
