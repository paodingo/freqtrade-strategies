{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "plan_id",
    "generated_at",
    "batch_id",
    "packet_fingerprint",
    "advisory_fingerprint",
    "approval_fingerprint",
    "actions",
    "summary",
    "automatic_candidate_creation_authorized",
    "curation_drafting_authorized",
    "automatic_source_rebuild_authorized",
    "automatic_lesson_promotion_authorized",
    "execution_authorized",
    "plan_fingerprint"
  ],
  "properties": {
    "schema_version": {"const": "knowledge-review-post-approval-plan-v1"},
    "plan_id": {"type": "string", "pattern": "^knowledge-post-approval-plan-[a-f0-9]{16}$"},
    "generated_at": {"type": "string", "minLength": 1},
    "batch_id": {"type": "string", "pattern": "^knowledge-review-batch-[a-f0-9]{16}$"},
    "packet_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "advisory_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "approval_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "review_key",
          "review_event_id",
          "review_type",
          "target_id",
          "decision",
          "resulting_status",
          "action_type",
          "workflow_owner",
          "evidence",
          "manual_action_required",
          "automatic_execution_authorized"
        ],
        "properties": {
          "review_key": {"type": "string", "minLength": 1},
          "review_event_id": {"type": "string", "pattern": "^knowledge-review-[a-f0-9]{16}$"},
          "review_type": {"enum": ["source_update", "lesson_feedback", "license_review"]},
          "target_id": {"type": "string", "minLength": 1},
          "decision": {"enum": ["approved", "rejected"]},
          "resulting_status": {"enum": ["approved_for_manual_rebuild", "approved_for_manual_curation", "active_pinned", "rejected", "deprecated"]},
          "action_type": {"enum": ["prepare_non_authoritative_lesson_curation_draft", "manual_source_snapshot_rebuild", "manual_source_metadata_rebuild", "closed_no_follow_up"]},
          "workflow_owner": {"enum": ["knowledge_curator", "human_source_maintainer", "none"]},
          "evidence": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "manual_action_required": {"type": "boolean"},
          "automatic_execution_authorized": {"const": false}
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": ["lesson_curation_drafts", "source_snapshot_rebuilds", "source_metadata_rebuilds", "closed", "total"],
      "properties": {
        "lesson_curation_drafts": {"type": "integer", "minimum": 0},
        "source_snapshot_rebuilds": {"type": "integer", "minimum": 0},
        "source_metadata_rebuilds": {"type": "integer", "minimum": 0},
        "closed": {"type": "integer", "minimum": 0},
        "total": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "automatic_candidate_creation_authorized": {"const": false},
    "curation_drafting_authorized": {"const": true},
    "automatic_source_rebuild_authorized": {"const": false},
    "automatic_lesson_promotion_authorized": {"const": false},
    "execution_authorized": {"const": false},
    "plan_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "additionalProperties": false
}
