{
    "bot_name": "freqtrade-v65-live",
    "max_open_trades": 1,
    "stake_currency": "USDT",
    "stake_amount": 250,
    "tradable_balance_ratio": 0.99,
    "fiat_display_currency": "USD",
    "dry_run": false,
    "db_url": "sqlite:////freqtrade/project/user_data/tradesv3_v65.live.sqlite",
    "cancel_open_orders_on_exit": false,
    "trading_mode": "futures",
    "margin_mode": "isolated",
    "exchange": {
        "name": "binance",
        "key": "",
        "secret": "",
        "ccxt_config": {
            "options": {
                "defaultType": "swap"
            }
        },
        "ccxt_async_config": {
            "options": {
                "defaultType": "swap"
            }
        },
        "pair_whitelist": ["BTC/USDT:USDT"]
    },
    "pairlists": [
        {
            "method": "StaticPairList",
            "allow_inactive": false
        }
    ],
    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1
    },
    "exit_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1
    },
    "order_types": {
        "entry": "limit",
        "exit": "limit",
        "stoploss": "market",
        "stoploss_on_exchange": true,
        "stoploss_on_exchange_interval": 60
    },
    "api_server": {
        "enabled": true,
        "listen_ip_address": "127.0.0.1",
        "listen_port": 8084,
        "verbosity": "error",
        "enable_openapi": false,
        "jwt_secret_key": "replace-this-live-jwt-secret-min-32-chars",
        "CORS_origins": [],
        "username": "freqtrader",
        "password": "replace-this-live-api-password"
    }
}
