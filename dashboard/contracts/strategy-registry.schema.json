{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/freqtrade/strategy-registry-v1.schema.json",
  "title": "Strategy Registry v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_id",
    "generated_at",
    "authority",
    "research_state_path",
    "comparison",
    "strategies"
  ],
  "properties": {
    "schema_version": { "const": "strategy-registry-v1" },
    "registry_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "description"],
      "properties": {
        "kind": { "const": "deployment_runtime_manifest" },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "research_state_path": { "type": "string", "minLength": 1 },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base_strategy_id", "challenger_strategy_id", "chart_source_strategy_id"],
      "properties": {
        "base_strategy_id": { "type": "string", "minLength": 1 },
        "challenger_strategy_id": { "type": "string", "minLength": 1 },
        "chart_source_strategy_id": { "type": "string", "minLength": 1 }
      }
    },
    "strategies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "strategy_id",
          "display_name",
          "version",
          "role",
          "stage",
          "strategy_class",
          "description",
          "runtime",
          "capabilities"
        ],
        "properties": {
          "strategy_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
          "display_name": { "type": "string", "minLength": 1 },
          "version": { "type": ["string", "null"] },
          "role": { "enum": ["current", "benchmark", "shadow", "candidate", "retired"] },
          "stage": { "enum": ["research", "approved", "dry_run", "live", "retired"] },
          "strategy_class": { "type": ["string", "null"] },
          "description": { "type": "string", "minLength": 1 },
          "runtime": {
            "type": "object",
            "additionalProperties": false,
            "required": ["bot_key", "source", "label_env"],
            "properties": {
              "bot_key": { "type": "string", "minLength": 1 },
              "source": { "enum": ["freqtrade", "sqlite"] },
              "label_env": { "type": ["string", "null"] },
              "url": {
                "type": "object",
                "additionalProperties": false,
                "required": ["env", "default"],
                "properties": {
                  "env": { "type": "string", "minLength": 1 },
                  "default": { "type": "string", "format": "uri" }
                }
              },
              "sqlite": {
                "type": "object",
                "additionalProperties": false,
                "required": ["env", "default_relative_path"],
                "properties": {
                  "env": { "type": "string", "minLength": 1 },
                  "default_relative_path": { "type": "string", "minLength": 1 }
                }
              },
              "bot_name": { "type": "string" },
              "runmode": { "type": "string" },
              "dry_run": { "type": "boolean" },
              "state": { "type": "string" },
              "max_open_trades": { "type": "number" },
              "stake_amount": { "type": "number" },
              "stake_currency": { "type": "string" }
            },
            "allOf": [
              {
                "if": { "properties": { "source": { "const": "freqtrade" } } },
                "then": { "required": ["url"] }
              },
              {
                "if": { "properties": { "source": { "const": "sqlite" } } },
                "then": { "required": ["sqlite", "bot_name", "runmode", "dry_run", "state"] }
              }
            ]
          },
          "capabilities": {
            "type": "object",
            "additionalProperties": false,
            "required": ["live_status", "positions", "performance", "research_evidence"],
            "properties": {
              "live_status": { "type": "boolean" },
              "positions": { "type": "boolean" },
              "performance": { "type": "boolean" },
              "research_evidence": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
